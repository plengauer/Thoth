{
  "version": 21,
  "variables": [
    {
      "version": 2,
      "key": "Repository",
      "type": "query",
      "visible": true,
      "editable": true,
      "input": "timeseries sum(github.actions.jobs), by: { github.repository.name }\n| summarize distinctRepositoryNames = collectDistinct(github.repository.name)\n| expand distinctRepositoryNames\n| sort distinctRepositoryNames",
      "multiple": true,
      "defaultValue": [
        "3420b2ac-f1cf-4b24-b62d-61ba1ba8ed05*"
      ]
    },
    {
      "version": 2,
      "key": "Branch",
      "type": "query",
      "visible": true,
      "editable": true,
      "input": "timeseries sum(github.actions.jobs), filter: { in(github.repository.name, array($Repository)) }, by: { github.actions.event.ref.name }\n| summarize distinctRepositoryNames = collectDistinct(github.actions.event.ref.name)\n| expand distinctRepositoryNames\n| sort distinctRepositoryNames",
      "multiple": true,
      "defaultValue": [
        "3420b2ac-f1cf-4b24-b62d-61ba1ba8ed05*"
      ]
    },
    {
      "version": 2,
      "key": "Trigger",
      "type": "query",
      "visible": true,
      "input": "timeseries sum(github.actions.jobs), filter: { in(github.repository.name, array($Repository)) }, by: { github.actions.event.name }\n| summarize distinctRepositoryNames = collectDistinct(github.actions.event.name)\n| expand distinctRepositoryNames\n| sort distinctRepositoryNames",
      "multiple": true,
      "defaultValue": [
        "3420b2ac-f1cf-4b24-b62d-61ba1ba8ed05*"
      ]
    },
    {
      "version": 2,
      "key": "Actor",
      "type": "query",
      "visible": true,
      "editable": true,
      "input": "timeseries sum(github.actions.jobs), filter: { in(github.repository.name, array($Repository)) }, by: { github.actions.actor.name }\n| summarize distinctRepositoryNames = collectDistinct(github.actions.actor.name)\n| expand distinctRepositoryNames\n| sort distinctRepositoryNames",
      "multiple": true,
      "defaultValue": [
        "3420b2ac-f1cf-4b24-b62d-61ba1ba8ed05*"
      ]
    }
  ],
